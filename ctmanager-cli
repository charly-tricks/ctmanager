#!/bin/bash
# ============================================================
#  CTMANAGER-CLI  -  by CHARLY_TRICKS
#  Gestion de usuarios SSH sin ADMRufu, no interactiva.
#  Pensado para ser invocado por sshvendor-bot.
#  Version 0.1
# ============================================================
#
#  USO:
#    ctmanager-cli add USER PASS DIAS LIMITE
#    ctmanager-cli renew USER DIAS
#    ctmanager-cli passwd USER NEWPASS
#    ctmanager-cli limit USER N
#    ctmanager-cli lock USER
#    ctmanager-cli unlock USER
#    ctmanager-cli del USER [--keep-home]
#    ctmanager-cli info USER
#    ctmanager-cli list
#    ctmanager-cli check            (bloquea vencidos - para cron)
#    ctmanager-cli sync             (reconcilia DB -> sistema)
#    ctmanager-cli limiter-daemon   (loop que mata conexiones de mas)
#    ctmanager-cli install-limiter  (crea el servicio systemd)
#
#  Cualquier comando acepta --json para salida parseable.
#  Codigos de salida: 0 ok | 1 error generico | 2 uso incorrecto
#                     3 usuario no existe | 4 usuario ya existe
# ============================================================

set -uo pipefail

DB="/etc/ctmanager/config/ssh_users.db"
LOG="/etc/ctmanager/logs/cli.log"
LIMITER_INTERVAL="${CTMANAGER_LIMITER_INTERVAL:-20}"

JSON=0
EXIT_CODE=0

# ── Preparacion ──────────────────────────────────────────────
[ "$(id -u)" -eq 0 ] || { echo "ctmanager-cli: se requiere root" >&2; exit 1; }
mkdir -p "$(dirname "$DB")" "$(dirname "$LOG")"

command -v sqlite3 >/dev/null 2>&1 || {
    echo "ctmanager-cli: falta sqlite3" >&2; exit 1; }

log() { echo "[$(date '+%F %T')] $*" >> "$LOG"; }

# ── Esquema ──────────────────────────────────────────────────
init_db() {
    sqlite3 "$DB" "CREATE TABLE IF NOT EXISTS users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        username   TEXT UNIQUE NOT NULL,
        password   TEXT NOT NULL,
        limite     INTEGER DEFAULT 1,
        mb_limit   INTEGER DEFAULT 0,
        bytes_uso  INTEGER DEFAULT 0,
        created_at TEXT DEFAULT (datetime('now')),
        expires_at TEXT,
        activo     INTEGER DEFAULT 1
    );" 2>/dev/null
    # Columnas agregadas respecto del esquema viejo de ctmanager.sh
    sqlite3 "$DB" "ALTER TABLE users ADD COLUMN limite INTEGER DEFAULT 1;" 2>/dev/null
    sqlite3 "$DB" "ALTER TABLE users ADD COLUMN mb_limit INTEGER DEFAULT 0;" 2>/dev/null
    sqlite3 "$DB" "ALTER TABLE users ADD COLUMN bytes_uso INTEGER DEFAULT 0;" 2>/dev/null
    return 0
}

# ── Salida ───────────────────────────────────────────────────
# Todo pasa por aca. Nunca imprimir directo desde los comandos.
ok() {   # ok "mensaje" [par clave=valor ...]
    local msg="$1"; shift
    if [ "$JSON" -eq 1 ]; then
        local extra=""
        for kv in "$@"; do
            extra="$extra,\"${kv%%=*}\":\"$(jesc "${kv#*=}")\""
        done
        echo "{\"ok\":true,\"msg\":\"$(jesc "$msg")\"$extra}"
    else
        echo "[OK] $msg"
        for kv in "$@"; do echo "     ${kv%%=*}: ${kv#*=}"; done
    fi
}

fail() {  # fail CODIGO "mensaje"
    local code="$1"; local msg="$2"
    if [ "$JSON" -eq 1 ]; then
        echo "{\"ok\":false,\"code\":$code,\"error\":\"$(jesc "$msg")\"}"
    else
        echo "[ERROR] $msg" >&2
    fi
    log "ERROR($code): $msg"
    exit "$code"
}

# Escape para JSON. El charset validado ya excluye lo peligroso,
# esto es cinturon y tiradores.
jesc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

# Escape para SQLite: duplicar comilla simple.
sesc() { printf '%s' "$1" | sed "s/'/''/g"; }

# ── Validaciones ─────────────────────────────────────────────
# Charset restringido a proposito: si no entra nada raro, no hay
# inyeccion posible ni sorpresas al pasar por el bot.
valid_user() {
    # Hasta 32 caracteres: un HWID de HTTP Custom son 32 hex.
    [[ "$1" =~ ^[a-z_0-9][a-z0-9_-]{2,31}$ ]] || return 1
    # Nombres reservados del sistema
    case "$1" in
        root|daemon|bin|sys|sync|games|man|lp|mail|news|uucp|proxy|\
        www-data|backup|list|irc|gnats|nobody|systemd*|sshd|ubuntu|debian)
            return 1 ;;
    esac
    return 0
}

valid_pass() {
    [[ "$1" =~ ^[A-Za-z0-9._@#%+=:-]{4,64}$ ]] || return 1
    return 0
}

valid_num() { [[ "$1" =~ ^[0-9]{1,5}$ ]] || return 1; return 0; }

db_has() {
    local u; u="$(sesc "$1")"
    local n; n=$(sqlite3 "$DB" "SELECT COUNT(*) FROM users WHERE username='$u';" 2>/dev/null)
    [ "${n:-0}" -gt 0 ]
}

# ════════════════════════════════════════════════════════════
#  CONTABILIDAD DE DATOS (iptables por UID)
# ════════════════════════════════════════════════════════════
# Como funciona:
#   Cada usuario tiene una regla en la cadena CTMANAGER_ACCT que
#   cuenta los bytes que emite su proceso sshd. Eso incluye tanto
#   lo que el cliente sube a internet como lo que baja hacia el
#   cliente, porque en ambos casos el que envia es sshd.
#   El demonio lee los contadores, los suma en la base y los
#   pone en cero de forma atomica (-Z).
ACCT_CHAIN="CTMANAGER_ACCT"
ACCT_INTERVAL="${CTMANAGER_ACCT_INTERVAL:-60}"

acct_disponible() {
    command -v iptables >/dev/null 2>&1 || return 1
    iptables -m owner --help >/dev/null 2>&1 || true
    return 0
}

acct_init_chain() {
    iptables -N "$ACCT_CHAIN" 2>/dev/null
    # Enganchar la cadena a OUTPUT una sola vez
    iptables -C OUTPUT -j "$ACCT_CHAIN" 2>/dev/null \
        || iptables -I OUTPUT -j "$ACCT_CHAIN" 2>/dev/null
    return 0
}

acct_add_user() {
    local user="$1"
    local uid; uid=$(id -u "$user" 2>/dev/null) || return 1
    acct_init_chain
    iptables -C "$ACCT_CHAIN" -m owner --uid-owner "$uid" \
        -m comment --comment "ctm:$user" -j RETURN 2>/dev/null && return 0
    iptables -A "$ACCT_CHAIN" -m owner --uid-owner "$uid" \
        -m comment --comment "ctm:$user" -j RETURN 2>/dev/null
    return 0
}

acct_del_user() {
    local user="$1"
    local uid; uid=$(id -u "$user" 2>/dev/null)
    [ -n "$uid" ] && iptables -D "$ACCT_CHAIN" -m owner --uid-owner "$uid" \
        -m comment --comment "ctm:$user" -j RETURN 2>/dev/null
    return 0
}

# Lee y resetea los contadores. Devuelve lineas "usuario bytes".
acct_leer_y_resetear() {
    iptables -L "$ACCT_CHAIN" -vnxZ 2>/dev/null | awk '
        /ctm:/ {
            bytes = $2
            for (i = 1; i <= NF; i++) {
                if ($i ~ /^ctm:/) {
                    sub(/^ctm:/, "", $i)
                    print $i, bytes
                    break
                }
            }
        }'
}

mb_humano() {   # bytes -> texto legible
    local b="${1:-0}"
    if   [ "$b" -ge 1073741824 ]; then awk "BEGIN{printf \"%.2f GB\", $b/1073741824}"
    elif [ "$b" -ge 1048576 ];    then awk "BEGIN{printf \"%.1f MB\", $b/1048576}"
    else echo "${b} B"; fi
}

cmd_quota() {
    local user="${1:-}" cant="${2:-}" unidad="${3:-GB}"
    [ -n "$user" ] && [ -n "$cant" ] || fail 2 "uso: quota USER CANTIDAD [MB|GB]   (0 = ilimitado)"
    valid_user "$user" || fail 2 "usuario invalido"
    valid_num  "$cant" || fail 2 "la cantidad debe ser un numero entero"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    local mb
    case "${unidad^^}" in
        MB) mb=$cant ;;
        GB) mb=$((cant * 1024)) ;;
        TB) mb=$((cant * 1024 * 1024)) ;;
        *)  fail 2 "unidad invalida: usar MB, GB o TB" ;;
    esac

    local u; u="$(sesc "$user")"
    sqlite3 "$DB" "UPDATE users SET mb_limit=$mb WHERE username='$u';" 2>/dev/null
    log "quota $user = ${cant}${unidad^^}"
    ok "cuota actualizada" "usuario=$user" \
       "cuota=$([ "$mb" -eq 0 ] && echo ilimitada || echo "${cant} ${unidad^^}")" \
       "mb=$mb"
}

cmd_usage() {
    local user="${1:-}"
    [ -n "$user" ] || fail 2 "uso: usage USER"
    valid_user "$user" || fail 2 "usuario invalido"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    local u; u="$(sesc "$user")"
    local row; row=$(sqlite3 "$DB" "SELECT COALESCE(bytes_uso,0), COALESCE(mb_limit,0),
        COALESCE(expires_at,''), activo FROM users WHERE username='$u';" 2>/dev/null)
    IFS='|' read -r bytes mblim exp act <<< "$row"

    local limbytes=$((mblim * 1048576))
    local pct=0
    [ "$limbytes" -gt 0 ] && pct=$(( bytes * 100 / limbytes ))
    local restante=0
    [ "$limbytes" -gt 0 ] && restante=$(( limbytes - bytes ))
    [ "$restante" -lt 0 ] && restante=0

    if [ "$JSON" -eq 1 ]; then
        echo "{\"ok\":true,\"usuario\":\"$(jesc "$user")\",\"bytes\":$bytes,\
\"usado\":\"$(mb_humano "$bytes")\",\"cuota_mb\":$mblim,\
\"restante\":\"$([ "$limbytes" -gt 0 ] && mb_humano "$restante" || echo ilimitado)\",\
\"porcentaje\":$pct,\"expira\":\"$(jesc "$exp")\",\"activo\":$act}"
    else
        echo "  Usuario   : $user"
        echo "  Consumido : $(mb_humano "$bytes")"
        if [ "$limbytes" -gt 0 ]; then
            echo "  Cuota     : $((mblim / 1024)) GB  (${pct}% usado)"
            echo "  Restante  : $(mb_humano "$restante")"
        else
            echo "  Cuota     : ilimitada"
        fi
        echo "  Expira    : ${exp:-sin limite}"
    fi
}

cmd_reset_usage() {
    local arg="${1:-}"
    [ -n "$arg" ] || fail 2 "uso: reset-usage USER   |   reset-usage --all"

    if [ "$arg" = "--all" ]; then
        sqlite3 "$DB" "UPDATE users SET bytes_uso=0;" 2>/dev/null
        iptables -Z "$ACCT_CHAIN" 2>/dev/null
        log "reset-usage --all"
        ok "consumo reseteado para todos"
    else
        valid_user "$arg" || fail 2 "usuario invalido"
        db_has "$arg"     || fail 3 "el usuario no existe en la base"
        local u; u="$(sesc "$arg")"
        sqlite3 "$DB" "UPDATE users SET bytes_uso=0 WHERE username='$u';" 2>/dev/null
        log "reset-usage $arg"
        ok "consumo reseteado" "usuario=$arg"
    fi
}

cmd_accounting_daemon() {
    init_db
    acct_init_chain
    # Registrar a todos los usuarios activos por si el VPS se reinicio
    while IFS= read -r user; do
        [ -n "$user" ] && acct_add_user "$user"
    done < <(sqlite3 "$DB" "SELECT username FROM users WHERE activo=1;" 2>/dev/null)

    log "contador de datos iniciado (intervalo ${ACCT_INTERVAL}s)"
    while true; do
        while read -r user bytes; do
            [ -z "$user" ] && continue
            [ "${bytes:-0}" -eq 0 ] && continue
            valid_user "$user" || continue
            local u; u="$(sesc "$user")"
            sqlite3 "$DB" "UPDATE users SET bytes_uso = COALESCE(bytes_uso,0) + $bytes
                           WHERE username='$u';" 2>/dev/null
        done < <(acct_leer_y_resetear)

        # Bloquear a los que pasaron la cuota
        while IFS= read -r user; do
            [ -z "$user" ] && continue
            valid_user "$user" || continue
            usermod -L "$user" 2>/dev/null
            pkill -u "$user" 2>/dev/null
            local u; u="$(sesc "$user")"
            sqlite3 "$DB" "UPDATE users SET activo=0 WHERE username='$u';" 2>/dev/null
            log "cuota agotada, bloqueado: $user"
        done < <(sqlite3 "$DB" "SELECT username FROM users
                 WHERE activo=1 AND mb_limit > 0
                   AND bytes_uso >= mb_limit * 1048576;" 2>/dev/null)

        sleep "$ACCT_INTERVAL"
    done
}

cmd_install_accounting() {
    acct_disponible || fail 1 "iptables no esta disponible en este sistema"
    local self; self="$(readlink -f "$0")"
    acct_init_chain

    cat > /etc/systemd/system/ctmanager-acct.service <<EOF
[Unit]
Description=CTManager - contador de consumo de datos
After=network.target

[Service]
Type=simple
ExecStart=$self accounting-daemon
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable ctmanager-acct >/dev/null 2>&1
    systemctl restart ctmanager-acct

    ok "contador de datos instalado" "servicio=ctmanager-acct" \
       "intervalo=${ACCT_INTERVAL}s"
}

# ════════════════════════════════════════════════════════════
#  COMANDOS
# ════════════════════════════════════════════════════════════

cmd_add() {
    local user="${1:-}" pass="${2:-}" dias="${3:-}" limite="${4:-1}" gb="${5:-0}"
    [ -n "$user" ] && [ -n "$pass" ] && [ -n "$dias" ] \
        || fail 2 "uso: add USER PASS DIAS [LIMITE] [GB]"
    valid_user "$user"   || fail 2 "usuario invalido (3-31 chars, minusculas, empieza con letra)"
    valid_pass "$pass"   || fail 2 "password invalido (4-64 chars alfanumericos y ._@#%+=:-)"
    valid_num  "$dias"   || fail 2 "dias debe ser un numero"
    valid_num  "$limite" || fail 2 "limite debe ser un numero"
    valid_num  "$gb"     || fail 2 "GB debe ser un numero"

    id "$user" &>/dev/null && fail 4 "el usuario ya existe en el sistema"
    db_has "$user"        && fail 4 "el usuario ya existe en la base"

    local expira_sys expira_db
    if [ "$dias" -gt 0 ]; then
        expira_sys=$(date -d "+${dias} days" '+%Y-%m-%d')
        expira_db="datetime('now', '+${dias} days')"
    else
        expira_sys=""
        expira_db="NULL"
    fi

    # Usuario del sistema sin shell ni home: solo sirve para tunel.
    if [ -n "$expira_sys" ]; then
        useradd -M -N -s /bin/false -e "$expira_sys" "$user" 2>/dev/null \
            || fail 1 "no se pudo crear el usuario en el sistema"
    else
        useradd -M -N -s /bin/false "$user" 2>/dev/null \
            || fail 1 "no se pudo crear el usuario en el sistema"
    fi
    echo "$user:$pass" | chpasswd 2>/dev/null \
        || { userdel "$user" 2>/dev/null; fail 1 "no se pudo asignar el password"; }

    local u p mb
    u="$(sesc "$user")"; p="$(sesc "$pass")"; mb=$((gb * 1024))
    sqlite3 "$DB" "INSERT INTO users (username,password,limite,mb_limit,expires_at)
                   VALUES ('$u','$p',$limite,$mb,$expira_db);" 2>/dev/null \
        || { userdel "$user" 2>/dev/null; fail 1 "no se pudo guardar en la base"; }

    acct_add_user "$user"

    log "add $user dias=$dias limite=$limite gb=$gb"
    ok "usuario creado" "usuario=$user" "expira=${expira_sys:-sin limite}" \
       "limite=$limite" "cuota=$([ "$gb" -eq 0 ] && echo ilimitada || echo "${gb} GB")"
}

cmd_renew() {
    local user="${1:-}" dias="${2:-}"
    [ -n "$user" ] && [ -n "$dias" ] || fail 2 "uso: renew USER DIAS"
    valid_user "$user" || fail 2 "usuario invalido"
    valid_num  "$dias" || fail 2 "dias debe ser un numero"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    local u; u="$(sesc "$user")"
    # Si ya vencio, cuenta desde hoy. Si no, suma a lo que le queda.
    sqlite3 "$DB" "UPDATE users SET
        expires_at = CASE
            WHEN expires_at IS NULL OR expires_at < datetime('now')
                THEN datetime('now','+${dias} days')
            ELSE datetime(expires_at,'+${dias} days')
        END,
        activo = 1
        WHERE username='$u';" 2>/dev/null || fail 1 "error actualizando la base"

    local nueva fecha
    nueva=$(sqlite3 "$DB" "SELECT expires_at FROM users WHERE username='$u';" 2>/dev/null)
    fecha="${nueva%% *}"

    if id "$user" &>/dev/null; then
        chage -E "$fecha" "$user" 2>/dev/null
        usermod -U "$user" 2>/dev/null
    fi

    log "renew $user +$dias -> $fecha"
    ok "usuario renovado" "usuario=$user" "expira=$fecha"
}

cmd_passwd() {
    local user="${1:-}" pass="${2:-}"
    [ -n "$user" ] && [ -n "$pass" ] || fail 2 "uso: passwd USER NEWPASS"
    valid_user "$user" || fail 2 "usuario invalido"
    valid_pass "$pass" || fail 2 "password invalido"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    echo "$user:$pass" | chpasswd 2>/dev/null || fail 1 "no se pudo cambiar el password"
    local u p; u="$(sesc "$user")"; p="$(sesc "$pass")"
    sqlite3 "$DB" "UPDATE users SET password='$p' WHERE username='$u';" 2>/dev/null

    log "passwd $user"
    ok "password actualizado" "usuario=$user"
}

cmd_limit() {
    local user="${1:-}" n="${2:-}"
    [ -n "$user" ] && [ -n "$n" ] || fail 2 "uso: limit USER N"
    valid_user "$user" || fail 2 "usuario invalido"
    valid_num  "$n"    || fail 2 "limite debe ser un numero"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    local u; u="$(sesc "$user")"
    sqlite3 "$DB" "UPDATE users SET limite=$n WHERE username='$u';" 2>/dev/null
    log "limit $user = $n"
    ok "limite actualizado" "usuario=$user" "limite=$n"
}

cmd_lock() {
    local user="${1:-}"
    [ -n "$user" ] || fail 2 "uso: lock USER"
    valid_user "$user" || fail 2 "usuario invalido"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    usermod -L "$user" 2>/dev/null
    pkill -u "$user" 2>/dev/null
    local u; u="$(sesc "$user")"
    sqlite3 "$DB" "UPDATE users SET activo=0 WHERE username='$u';" 2>/dev/null
    log "lock $user"
    ok "usuario bloqueado" "usuario=$user"
}

cmd_unlock() {
    local user="${1:-}"
    [ -n "$user" ] || fail 2 "uso: unlock USER"
    valid_user "$user" || fail 2 "usuario invalido"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    usermod -U "$user" 2>/dev/null
    local u; u="$(sesc "$user")"
    sqlite3 "$DB" "UPDATE users SET activo=1 WHERE username='$u';" 2>/dev/null
    log "unlock $user"
    ok "usuario desbloqueado" "usuario=$user"
}

cmd_del() {
    local user="${1:-}" keep="${2:-}"
    [ -n "$user" ] || fail 2 "uso: del USER [--keep-home]"
    valid_user "$user" || fail 2 "usuario invalido"

    pkill -u "$user" 2>/dev/null
    sleep 1
    acct_del_user "$user"
    if [ "$keep" = "--keep-home" ]; then
        userdel "$user" 2>/dev/null
    else
        userdel -r "$user" 2>/dev/null
    fi
    local u; u="$(sesc "$user")"
    sqlite3 "$DB" "DELETE FROM users WHERE username='$u';" 2>/dev/null
    log "del $user"
    ok "usuario eliminado" "usuario=$user"
}

cmd_info() {
    local user="${1:-}"
    [ -n "$user" ] || fail 2 "uso: info USER"
    valid_user "$user" || fail 2 "usuario invalido"
    db_has "$user"     || fail 3 "el usuario no existe en la base"

    local u; u="$(sesc "$user")"
    local row; row=$(sqlite3 "$DB" "SELECT username, password, limite,
        COALESCE(expires_at,''), activo, created_at
        FROM users WHERE username='$u';" 2>/dev/null)

    IFS='|' read -r n p lim exp act crea <<< "$row"
    local conn; conn=$(contar_conexiones "$n")
    local en_sistema="no"; id "$n" &>/dev/null && en_sistema="si"
    local vencido="no"
    [ -n "$exp" ] && [[ "$exp" < "$(date '+%Y-%m-%d %H:%M:%S')" ]] && vencido="si"

    if [ "$JSON" -eq 1 ]; then
        echo "{\"ok\":true,\"usuario\":\"$(jesc "$n")\",\"password\":\"$(jesc "$p")\",\
\"limite\":$lim,\"conexiones\":$conn,\"expira\":\"$(jesc "$exp")\",\
\"activo\":$act,\"vencido\":\"$vencido\",\"en_sistema\":\"$en_sistema\",\
\"creado\":\"$(jesc "$crea")\"}"
    else
        echo "  Usuario     : $n"
        echo "  Password    : $p"
        echo "  Limite      : $lim dispositivos"
        echo "  Conectados  : $conn"
        echo "  Expira      : ${exp:-sin limite}"
        echo "  Activo      : $([ "$act" = "1" ] && echo si || echo no)"
        echo "  Vencido     : $vencido"
        echo "  En sistema  : $en_sistema"
        echo "  Creado      : $crea"
    fi
}

cmd_list() {
    init_db
    if [ "$JSON" -eq 1 ]; then
        local first=1
        printf '{"ok":true,"users":['
        while IFS='|' read -r n p lim exp act; do
            [ -z "$n" ] && continue
            [ $first -eq 0 ] && printf ','
            first=0
            printf '{"usuario":"%s","password":"%s","limite":%s,"conexiones":%s,"expira":"%s","activo":%s}' \
                "$(jesc "$n")" "$(jesc "$p")" "$lim" "$(contar_conexiones "$n")" "$(jesc "$exp")" "$act"
        done < <(sqlite3 "$DB" "SELECT username,password,COALESCE(limite,1),COALESCE(expires_at,''),activo FROM users ORDER BY id;" 2>/dev/null)
        printf ']}\n'
    else
        printf "  %-18s %-14s %-5s %-5s %-12s %-8s\n" "USUARIO" "PASSWORD" "LIM" "CONN" "EXPIRA" "ESTADO"
        echo "  ------------------------------------------------------------------------"
        while IFS='|' read -r n p lim exp act; do
            [ -z "$n" ] && continue
            printf "  %-18s %-14s %-5s %-5s %-12s %-8s\n" \
                "$n" "$p" "$lim" "$(contar_conexiones "$n")" "${exp%% *}" \
                "$([ "$act" = "1" ] && echo activo || echo bloqueado)"
        done < <(sqlite3 "$DB" "SELECT username,password,COALESCE(limite,1),COALESCE(expires_at,''),activo FROM users ORDER BY id;" 2>/dev/null)
    fi
}

cmd_check() {
    init_db
    local venc; venc=$(sqlite3 "$DB" "SELECT username FROM users
        WHERE expires_at IS NOT NULL
          AND expires_at < datetime('now')
          AND activo = 1;" 2>/dev/null)

    local n=0
    for user in $venc; do
        usermod -L "$user" 2>/dev/null
        pkill -u "$user" 2>/dev/null
        local u; u="$(sesc "$user")"
        sqlite3 "$DB" "UPDATE users SET activo=0 WHERE username='$u';" 2>/dev/null
        log "expirado y bloqueado: $user"
        n=$((n+1))
    done
    ok "revision completa" "bloqueados=$n"
}

# Reconstruye los usuarios del sistema a partir de la base.
# Sirve si reinstalas el VPS o si algo se desincronizo.
cmd_sync() {
    init_db
    local creados=0 ajustados=0
    while IFS='|' read -r n p exp act; do
        [ -z "$n" ] && continue
        if ! id "$n" &>/dev/null; then
            useradd -M -N -s /bin/false "$n" 2>/dev/null && creados=$((creados+1))
            echo "$n:$p" | chpasswd 2>/dev/null
        fi
        if [ -n "$exp" ]; then
            chage -E "${exp%% *}" "$n" 2>/dev/null
        fi
        if [ "$act" = "1" ]; then usermod -U "$n" 2>/dev/null
        else usermod -L "$n" 2>/dev/null; fi
        ajustados=$((ajustados+1))
    done < <(sqlite3 "$DB" "SELECT username,password,COALESCE(expires_at,''),activo FROM users;" 2>/dev/null)
    log "sync creados=$creados ajustados=$ajustados"
    ok "sincronizacion completa" "creados=$creados" "ajustados=$ajustados"
}

# ════════════════════════════════════════════════════════════
#  LIMITADOR DE CONEXIONES
# ════════════════════════════════════════════════════════════
# Cuenta los procesos sshd/dropbear que corren bajo el usuario.
# Cada tunel activo deja uno, asi que sirve como contador de
# dispositivos conectados.
contar_conexiones() {
    local user="$1"
    local n
    n=$(ps -u "$user" -o comm= 2>/dev/null | grep -cE '^(sshd|dropbear)$')
    echo "${n:-0}"
}

# Devuelve los PIDs mas nuevos primero (los ultimos en conectarse).
pids_recientes() {
    local user="$1"
    ps -u "$user" -o pid=,comm= 2>/dev/null \
        | awk '$2=="sshd" || $2=="dropbear" {print $1}' \
        | sort -rn
}

cmd_limiter_daemon() {
    init_db
    log "limiter iniciado (intervalo ${LIMITER_INTERVAL}s)"
    while true; do
        while IFS='|' read -r user lim; do
            [ -z "$user" ] && continue
            [ "${lim:-0}" -le 0 ] && continue          # 0 = sin limite
            local conn; conn=$(contar_conexiones "$user")
            if [ "$conn" -gt "$lim" ]; then
                local sobra=$((conn - lim))
                local matados=0
                for pid in $(pids_recientes "$user"); do
                    [ "$matados" -ge "$sobra" ] && break
                    kill -9 "$pid" 2>/dev/null && matados=$((matados+1))
                done
                log "limite excedido: $user ($conn/$lim) -> $matados cerradas"
            fi
        done < <(sqlite3 "$DB" "SELECT username,COALESCE(limite,1) FROM users WHERE activo=1;" 2>/dev/null)
        sleep "$LIMITER_INTERVAL"
    done
}

cmd_install_limiter() {
    local self; self="$(readlink -f "$0")"
    cat > /etc/systemd/system/ctmanager-limiter.service <<EOF
[Unit]
Description=CTManager - limitador de conexiones simultaneas
After=network.target

[Service]
Type=simple
ExecStart=$self limiter-daemon
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable ctmanager-limiter >/dev/null 2>&1
    systemctl restart ctmanager-limiter

    # Cron diario para bloquear vencidos
    cat > /etc/cron.d/ctmanager-check <<EOF
0 * * * * root $self check >/dev/null 2>&1
EOF
    chmod 644 /etc/cron.d/ctmanager-check

    ok "limitador instalado" "servicio=ctmanager-limiter" "cron=/etc/cron.d/ctmanager-check"
}

# ════════════════════════════════════════════════════════════
#  DESINSTALACION
# ════════════════════════════════════════════════════════════
# Deja el VPS como estaba: saca el servicio, el cron, los
# usuarios creados, la base y el binario.
# Requiere --yes para no borrar nada por accidente.
cmd_uninstall() {
    local confirm="${1:-}"
    if [ "$confirm" != "--yes" ]; then
        if [ "$JSON" -eq 1 ]; then
            fail 2 "requiere --yes para confirmar"
        fi
        echo "  ATENCION: esto elimina TODO lo que instalo ctmanager-cli:"
        echo "    - servicio ctmanager-limiter"
        echo "    - cron de vencimientos"
        echo "    - TODOS los usuarios SSH creados (y los desconecta)"
        echo "    - la base de datos $DB"
        echo "    - el binario /usr/local/bin/ctmanager-cli"
        echo ""
        echo "  Si estas seguro:  ctmanager-cli uninstall --yes"
        exit 2
    fi

    local borrados=0

    # 1. Parar el limitador y el contador de datos
    systemctl stop ctmanager-limiter 2>/dev/null
    systemctl disable ctmanager-limiter 2>/dev/null
    rm -f /etc/systemd/system/ctmanager-limiter.service
    systemctl stop ctmanager-acct 2>/dev/null
    systemctl disable ctmanager-acct 2>/dev/null
    rm -f /etc/systemd/system/ctmanager-acct.service
    systemctl daemon-reload 2>/dev/null

    # 1b. Sacar las reglas de contabilidad
    iptables -D OUTPUT -j "$ACCT_CHAIN" 2>/dev/null
    iptables -F "$ACCT_CHAIN" 2>/dev/null
    iptables -X "$ACCT_CHAIN" 2>/dev/null

    # 2. Sacar el cron
    rm -f /etc/cron.d/ctmanager-check

    # 3. Eliminar los usuarios que creamos (solo los que estan en la base)
    while IFS= read -r user; do
        [ -z "$user" ] && continue
        valid_user "$user" || continue
        pkill -u "$user" 2>/dev/null
        userdel -r "$user" 2>/dev/null
        borrados=$((borrados+1))
    done < <(sqlite3 "$DB" "SELECT username FROM users;" 2>/dev/null)

    # 4. Base y logs
    rm -f "$DB"
    rm -f "$LOG"
    rmdir "$(dirname "$DB")" 2>/dev/null
    rmdir "$(dirname "$LOG")" 2>/dev/null
    rmdir /etc/ctmanager 2>/dev/null

    ok "desinstalacion completa" "usuarios_eliminados=$borrados" \
       "nota=el binario se borra al salir"

    # 5. El binario, al final. Borrarse a si mismo es seguro en
    #    Linux: el proceso ya esta cargado en memoria.
    rm -f /usr/local/bin/ctmanager-cli
    exit 0
}

# ════════════════════════════════════════════════════════════
#  DISPATCH
# ════════════════════════════════════════════════════════════
uso() {
cat <<'EOF'
ctmanager-cli - gestion de usuarios SSH (by CHARLY_TRICKS)

  add USER PASS DIAS [LIMITE] [GB]   crear cuenta
  renew USER DIAS               sumar dias
  passwd USER NEWPASS           cambiar clave
  limit USER N                  cambiar limite de dispositivos
  quota USER GB                 cambiar cuota de datos (0 = ilimitada)
  usage USER                    ver consumo de datos
  reset-usage USER | --all      poner el consumo en cero
  lock USER                     bloquear
  unlock USER                   desbloquear
  del USER [--keep-home]        eliminar
  info USER                     ver una cuenta
  list                          listar todas
  check                         bloquear vencidos (cron)
  sync                          rehacer usuarios del sistema desde la base
  install-limiter               instalar servicio + cron
  install-accounting            instalar contador de datos
  limiter-daemon                loop del limitador (lo usa systemd)
  accounting-daemon             loop del contador (lo usa systemd)
  uninstall --yes               borrar TODO lo instalado

  Agregar --json a cualquier comando para salida parseable.
EOF
}

# Extraer --json de los argumentos, sin importar la posicion
ARGS=()
for a in "$@"; do
    if [ "$a" = "--json" ]; then JSON=1; else ARGS+=("$a"); fi
done
set -- "${ARGS[@]:-}"

init_db

case "${1:-}" in
    add)             shift; cmd_add "$@" ;;
    renew)           shift; cmd_renew "$@" ;;
    passwd)          shift; cmd_passwd "$@" ;;
    limit)           shift; cmd_limit "$@" ;;
    quota)           shift; cmd_quota "$@" ;;
    usage)           shift; cmd_usage "$@" ;;
    reset-usage)     shift; cmd_reset_usage "$@" ;;
    lock)            shift; cmd_lock "$@" ;;
    unlock)          shift; cmd_unlock "$@" ;;
    del)             shift; cmd_del "$@" ;;
    info)            shift; cmd_info "$@" ;;
    list)            shift; cmd_list "$@" ;;
    check)           shift; cmd_check "$@" ;;
    sync)            shift; cmd_sync "$@" ;;
    limiter-daemon)  shift; cmd_limiter_daemon ;;
    install-limiter)    shift; cmd_install_limiter ;;
    install-accounting) shift; cmd_install_accounting ;;
    accounting-daemon)  shift; cmd_accounting_daemon ;;
    uninstall)       shift; cmd_uninstall "$@" ;;
    ""|-h|--help)    uso ;;
    *)               fail 2 "comando desconocido: $1" ;;
esac

exit $EXIT_CODE
